use Libraries.Web.Page.all
use Libraries.Containers.Array

class SceneCreation is Lesson
    text dq = ""
    dq = dq:GetDoubleQuote()
    text cr = ""
    cr = cr:GetCarriageReturn()
    Preformatter preformatter //helper

    action Setup
        //html header stuff
        SetWebPageTitle("Create a Scene Project - Quorum Programming Language")
        AddDefaultHeaders()

        Array<Division> divs = InitializeTutorialPage()
        Division bodyDiv = divs:Get(1)
        Division onPageDiv = divs:Get(2)


        //page header
        Header headDiv
        headDiv:SetClassAttribute("flex flex-col gap-y-2")
        Heading h_heading = headDiv:AddHeading("Create a Scene Project", 1)
        h_heading:AddClassAttribute("text-3xl font-bold")
        h_heading:AddAttribute("data-text", "Create a Scene Project")
        AddToHeadingArray(h_heading)

        headDiv:AddText("This tutorial discusses how you actually make a project with a scene in it.")
        bodyDiv:Add(headDiv)

        Section section_new
        section_new:AddClassAttribute("flex flex-col gap-y-2")
        bodyDiv:Add(section_new)
        AddHeading(section_new, "Creating a New Project", 2)

        section_new:AddParagraph("To create a New Scene Project, either click File -> New Project, or use the keyboard commands: COMMAND + N on Mac, or CONTROL + N on Windows. From here, a New Project Dialog appears:")
        
        Image newSceneImage = section_new:AddImage("/media/scenes/CreateScene/SceneCreate1.png","This image is the new project window. It contains a tree of possible new projects, such as a blank project, various kinds of graphical projects, and others. This highlights Scenes -> 3D Scene project. 
            Below is a description of the type of project selected, then a Name blank, save location line, Browse Button, Cancel Button, and Ok Button.")
        newSceneImage:AddAttribute("data-zoom","")
        section_new:AddParagraph("Navigate to Games and then select either a 2D or 3D scene. The reason this selection matters is because Quorum will load the default assets for that kind of game into your project. ")

        section_new:AddParagraph("After the project is created, the screen shows the project, with several items created by default. The first folder " + dq + "Scenes," + dq + " which has the file Scene.qs. This is a blank Quorum scene file. 
            The next folder " + dq + "Resources" + dq + " contains the " + dq + "Tilesets" + dq + " folder with 6 files. Three PNG picture files, and three files with the extension JSON. JSON is a file format called JavaScript Object Notation (JSON). 
            These files allow visual images on the screen, as well as text descriptions. The third folder " + dq + "Source 
Code," + dq + " which has the Main.quourm file. That file contains the code to run the scene.")
        
        Image image = section_new:AddImage("/media/scenes/CreateScene/SceneCreate2.png",
"This image is Quorum Studio with a new window open where you can put the name of your project and press ok.")
        
        image:AddAttribute("data-zoom","")
        section_new:AddParagraph("To open the scene, select Scene. By default, the 2D part of the scene is loaded. The change to the 3D view, use COMMAND+1 or CONTROL+1 to navigate back to the project window. Then go to the scenes and select the one you want. You can also use the mouse and click on the tabs. Quorum uses these as a form of layers. For example, a game could have a 3d component with a user interface layered on top representing some kind of health or magic. You know, use the force, Harry.")


        Section nextLesson
        nextLesson:AddClassAttribute("flex flex-col gap-y-2")
        bodyDiv:Add(nextLesson)
        WriteNextTutorial(nextLesson)    
        onPageDiv:Add(CreateHeadingTableOfContents())
    end

    action GetMetaDescription returns text
        return "Learn to create a new Scene Project in Quorum Studio."
    end

    action GetSummaryName returns text
        return "Creating a scene project"
    end

    action GetName returns text
        return "Creating a scene project"
    end

    action GetShortDescription returns text
        return "creating a scene project in Quorum Studio"
    end

    action GetLocation returns text
        return "tutorials/Scenes/create.html"
    end

       action GetLinkName returns text
        return "Create a Scene Project"
    end

    action GetSectionName returns text
        return "Scene Editing"
    end
end